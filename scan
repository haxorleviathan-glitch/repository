// Fungsi getViewUrl kompatibel semua PHP
function getViewUrl($filePath) {
    $patterns = array('public_html', 'htdocs', 'var', 'www', 'html', 'httpdocs');
    
    foreach($patterns as $pattern) {
        $pos = strpos($filePath, $pattern);
        if($pos !== false) {
            $result = substr($filePath, $pos + strlen($pattern));
            if(strlen($result) > 0) {
                if($result[0] == '/' || $result[0] == '\\') {
                    $result = substr($result, 1);
                }
                return $result;
            }
        }
    }
    
    return $filePath;
}

// Fungsi scan dengan opendir (REKURSI YANG DIPERBAIKI - handle tetap terbuka)
function scanDirRecursive($dir){
    global $total, $found, $path;
    
    if(!is_dir($dir)) return;
    if(!is_readable($dir)) return;
    
    // Gunakan opendir (lebih universal dari scandir)
    $handle = @opendir($dir);
    if(!$handle) return;
    
    while(($item = @readdir($handle)) !== false) {
        if($item == '.' || $item == '..') continue;
        
        $full = $dir . '/' . $item;
        
        if(@is_dir($full)){
            // PERBAIKAN: HAPUS closedir DAN opendir ULANG
            // Handle tetap terbuka, rekursi berjalan normal
            scanDirRecursive($full);
            continue;
        }
        
        // Daftar ekstensi lengkap
        $ext = strtolower(pathinfo($full, PATHINFO_EXTENSION));
        $allowed = array('php','php1','php2','php3','php4','php5','php6','php7','php8','php9','php10','phtml','shtml','alfa','suspected');
        
        if(in_array($ext, $allowed)){
            // TANPA batasan jumlah file - scan semua
            $total++;
            checkFile($full);
        }
    }
    @closedir($handle);
}

// Fungsi checkFile kompatibel semua PHP
function checkFile($file){
    global $found, $path;
    
    if(!file_exists($file)) return false;
    
    // TANPA batasan ukuran file - scan semua ukuran
    $filesize = @filesize($file);
    if($filesize === false) return false;
    
    // Baca file dengan cara aman
    $content = @file_get_contents($file);
    if($content === false || strlen($content) == 0) return false;
    
    // Pattern detection
    $patterns_to_check = array(
    'eval', 'fsockopen', 'pfsockopen', '$func($var)', '${"var"}', 'assert',
    'system', 'exec', 'shell_exec', 'passthru', 'proc_open', 'popen',
    'pcntl_exec', 'expect_popen', 'curl_exec', 'move_uploaded_file',
    'base64_decode', 'gzinflate', 'str_rot13', 'hex2bin', 'bin2hex',
    'create_function', 'preg_replace', 'ob_start'
    );
    
    $found_patterns = array();
    $content_lower = strtolower($content);
    
    foreach($patterns_to_check as $pattern) {
        if(strpos($content_lower, $pattern) !== false) {
            $found_patterns[] = $pattern;
        }
    }
    
    if(empty($found_patterns)) return false;
    
    $found++;
    
    $mtime = @filemtime($file);
    $date = $mtime ? date('Y-m-d H:i:s', $mtime) : '-';
    $date_color = '#ff9b4a';
    $file_id = md5($file);
    $viewPath = getViewUrl($file);
    
    // Output HTML (sederhana dan kompatibel)
    echo '<div class="file-card" id="file-'.$file_id.'" data-file="'.htmlspecialchars($file, ENT_QUOTES).'">';
    echo '<div class="file-header">';
    echo '<div class="file-path">'.htmlspecialchars($file).'</div>';
    echo '<div class="file-date" style="color: '.$date_color.'; background: rgba(255,155,74,0.1); border: 1px solid rgba(255,155,74,0.3);">'.$date.'</div>';
    echo '</div>';
    
    echo '<div class="patterns">';
    foreach($found_patterns as $pattern){
        echo '<span class="pattern-tag">'.$pattern.'</span>';
    }
    echo '</div>';
    
    echo '<div class="content-wrapper">';
    echo '<div class="content-header">FILE CONTENT</div>';
    echo '<textarea class="file-content" readonly>';
    echo htmlspecialchars($content);
    echo '</textarea>';
    echo '</div>';
    
    echo '<div class="file-actions">';
    echo '<a href="'.htmlspecialchars($viewPath).'" target="_blank" class="btn-view">View</a>';
    echo '<button onclick="deleteFile(\''.$file_id.'\')" class="btn-delete">Delete File</button>';
    echo '</div>';
    echo '</div>';
    
    // Flush output agar progres terlihat
    if(function_exists('ob_flush')) {
        @ob_flush();
    }
    @flush();
    
    return true;
}

