// JavaScript delete function (kompatibel semua browser)
echo '<script>
function deleteFile(fileId){
    if(!confirm("Delete this file?")) return;
    var fileElement = document.getElementById("file-"+fileId);
    if(!fileElement) return;
    var filePath = fileElement.getAttribute("data-file");
    fileElement.classList.add("file-deleting");
    var deleteBtn = fileElement.querySelector(".btn-delete");
    var viewBtn = fileElement.querySelector(".btn-view");
    if(deleteBtn){ deleteBtn.disabled=true; deleteBtn.textContent="Deleting..."; }
    if(viewBtn){ viewBtn.style.pointerEvents="none"; viewBtn.style.opacity="0.5"; }
    var formData = new FormData();
    formData.append("delete_file","1");
    formData.append("file_path",filePath);
    fetch(window.location.href,{method:"POST",body:formData})
    .then(function(res){ return res.text(); })
    .then(function(result){
        if(result==="DELETED"){
            fileElement.classList.remove("file-deleting");
            fileElement.classList.add("file-deleted");
            if(deleteBtn) deleteBtn.style.display="none";
        }else{ alert("Failed: "+result); fileElement.classList.remove("file-deleting");
            if(deleteBtn){ deleteBtn.disabled=false; deleteBtn.textContent="Delete File"; }
            if(viewBtn){ viewBtn.style.pointerEvents="auto"; viewBtn.style.opacity="1"; }
        }
    })
    .catch(function(error){ alert("Error: "+error); });
}
