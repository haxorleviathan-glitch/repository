$total = $found = 0;

function getViewUrl($filePath) {
    // Cari posisi "public_html" dalam path
    $pos = strpos($filePath, 'public_html');
    if ($pos !== false) {
        // Ambil semua karakter setelah "public_html/"
        return substr($filePath, $pos + strlen('public_html/'));
    }
    // Jika tidak ditemukan public_html, kembalikan path asli
    return $filePath;
}

function checkFile($file){
    global $path, $found;
    
    if(!file_exists($file)) return false;
    
    $content = @file_get_contents($file);
    if($content === false || strlen($content) === 0) return false;
    
    $clean = preg_replace('/(\'.*?\'|".*?")/s',' ',$content);
    $clean = preg_replace('#/\*.*?\*/#s',' ',$clean);
    $clean = preg_replace('#//.*$#m',' ',$clean);
    
    $pattern = '#\b(eval|fsockopen|pfsockopen|\$func\(\$var\)|\$\{\"var\"\}|assert|system|exec|shell_exec|passthru|proc_open|popen|pcntl_exec|expect_popen|curl_exec|file_put_contents|move_uploaded_file|file_get_contents|base64_decode|gzinflate|str_rot13|hex2bin|bin2hex|create_function|preg_replace.*\/e|ob_start|register_shutdown_function|set_error_handler|call_user_func|call_user_func_array|array_map|array_filter|usort|uasort|uksort|xml_parse|mb_ereg_replace|filter_var|stream_filter_append|\$_GET\[['\"]cmd['\"]\]|\$_POST\[['\"]cmd['\"]\]|\$_REQUEST\[['\"]cmd['\"]\]|\$_COOKIE\[['\"]cmd['\"]\]|\$_(GET|POST|REQUEST|COOKIE|SERVER)\[['\"]?[a-zA-Z]+['\"]?\])\b#ix';
    preg_match_all($pattern, $clean, $matches);
    $found_patterns = array_unique(array_map('strtolower', $matches[0]));
    
    if(empty($found_patterns)) return false;
    
    $found++;
    
    $mtime = @filemtime($file);
    $date = $mtime ? date('Y-m-d H:i:s', $mtime) : '-';
    
    // Warna kuning terang untuk tanggal (sama dengan warna pattern)
    $date_color = '#ff9b4a';
    
    $file_id = md5($file);
    $viewPath = getViewUrl($file);
    
    echo '<div class="file-card" id="file-'.$file_id.'" data-file="'.htmlspecialchars($file, ENT_QUOTES).'">';
    echo '<div class="file-header">';
    echo '<div class="file-path">'.htmlspecialchars($file).'</div>';
    echo '<div class="file-date" style="color: '.$date_color.'; background: rgba(255,155,74,0.1); border: 1px solid rgba(255,155,74,0.3);">'.$date.'</div>';
    echo '</div>';
    
    echo '<div class="patterns">';
    foreach($found_patterns as $pattern){
        echo '<span class="pattern-tag">'.$pattern.'</span>';
    }
    echo '</div>';
    
    echo '<div class="content-wrapper">';
    echo '<div class="content-header">FILE CONTENT</div>';
    echo '<textarea class="file-content" readonly>';
    echo htmlspecialchars($content);
    echo '</textarea>';
    echo '</div>';
    
    echo '<div class="file-actions">';
    echo '<a href="'.htmlspecialchars($viewPath).'" target="_blank" class="btn-view">View</a>';
    echo '<button onclick="deleteFile(\''.$file_id.'\')" class="btn-delete">Delete File</button>';
    echo '</div>';
    echo '</div>';
    
    return true;
}

function scanDirRecursive($dir){
    global $total;
    if(!is_readable($dir)) return;
    
    $items = @scandir($dir);
    if(!$items) return;
    
    foreach($items as $item){
        if($item == '.' || $item == '..') continue;
        $full = $dir.'/'.$item;
        
        if(is_dir($full)){
            scanDirRecursive($full);
            continue;
        }
        
        $ext = strtolower(pathinfo($full, PATHINFO_EXTENSION));
        if(in_array($ext, ['php', 'php5', 'phtml'])){
            $total++;
            checkFile($full);
        }
    }
}

